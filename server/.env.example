PORT=3847
# Se carga al iniciar el servidor (antes no se leía server/.env con tsx; ya está resuelto).
ADMIN_SECRET=cambia-esto

# Opcional: persistir la sala en Supabase (solo en server/.env — nunca en el navegador).
# Tras añadir trazos/ítems: ejecutá server/supabase-trail-columns.sql en el SQL editor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Probar público con ngrok (tunnel al proceso de juego, puerto 3847 por defecto):
#   npm run tunnel:3847  (necesitás tener `ngrok` en PATH tras instalarlo y authtoken)
# Copiá la URL https y configurá NEXT_PUBLIC_GAME_SERVER en web/.env.local
